    "live-server": "^1.2.2",
    "md5": "^2.3.0",
    "msgpack-lite": "^0.1.26",
    "webpack-cli": "^3.3.12"
  },
  "resolutions": {
    "webpack/acorn": "^8.0.1",
    "webpack/eslint-scope": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "cross-env": "^7.0.2",
    "typescript": "^5.4.5"
  }
