{
  "name": "stratums-client-source",
  "description": "Unbundled Stratums.io client source code for local builds",
  "license": "MIT",
  "author": "Stratums Client Source",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/stratums-client-source.git"
  },
  "scripts": {
    "start": "live-server --port=6969 --host=0.0.0.0 --verbose",
